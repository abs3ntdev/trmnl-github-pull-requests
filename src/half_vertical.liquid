<div class="layout layout--col ">
  <div class="label">
    <i class="ti ti-brand-github">&nbsp;</i>PRs Needing Attention
  </div>
  {% if length == 0 %}
    <div class="layout layout--col">
      <i class="ti ti-check"></i>
      <span>No PRs need attention</span>
    </div>
  {% else %}
    <div class="columns">
      <div class="grid grid--cols-1" data-list-limit="true">
        <div class="list" data-overflow="true" data-overflow-counter="true">
          {% for pr in all_prs %}
            {% assign latest_review = pr.reviews.nodes | reject: 'author.login', username | sort: 'submittedAt' | last %}
            {% assign review_status = pr.reviewDecision | default: latest_review.state %}
            {% assign has_label = false %}
            {% for lbl in pr.labels.nodes %}
              {% if lbl.name == label_name %}{% assign has_label = true %}{% break %}{% endif %}
            {% endfor %}
            {% assign is_reviewer = false %}
            {% for rr in pr.reviewRequests.nodes %}
              {% if rr.requestedReviewer.login == username %}{% assign is_reviewer = true %}{% break %}{% endif %}
            {% endfor %}
            <div class="item {% if review_status == 'REVIEW_REQUIRED' or review_status == 'CHANGES_REQUESTED' %} item--emphasis-3 {% elsif review_status == 'COMMENTED' %} item--emphasis-2 {% endif %} ">
              <div class="meta w--6">
                <span class="index ml--0.5" data-pixel-perfect="true">
                  {% case review_status %}
                    {% when 'APPROVED' %}<div class="approved-icon svg-icon"></div>
                    {% when 'CHANGES_REQUESTED' %}<div class="changes-requested-icon svg-icon"></div>
                    {% when 'COMMENTED' %}<div class="commented-icon svg-icon"></div>
                    {% when 'PENDING' %}<div class="pending-icon svg-icon"></div>
                    {% when 'REVIEW_REQUIRED' %}<div class="review-required-icon svg-icon"></div>
                    {% else %}<div class="need-attention-icon svg-icon"></div>
                  {% endcase %}
                </span>
              </div>
              <div class="content">
                <span class="title title--small">
                  {% if pr.isDraft %}<i class="ti ti-git-pull-request-draft"></i>
                  {% else %}<i class="ti ti-git-pull-request"></i>{% endif %}
                  {{ pr.title | truncate: 35 }}
                  <span class="label label--small ">#{{ pr.number }}</span>
                </span>
                <span class="description">
                  {% if has_label %}<span class="reason-tag"><i class="ti ti-tag"></i> {{ label_name }}</span>{% endif %}
                  {% if is_reviewer %}<span class="reason-tag"><i class="ti ti-eye"></i> review</span>{% endif %}
                </span>
                <div class="flex gap--xsmall">
                  <span class="label label--small label--underline">
                    <i class="ti ti-message"></i> &nbsp;{{ pr.comments.totalCount }}
                  </span>
                  {% if latest_review %}
                  <span class="label label--small label--underline">
                    {{ latest_review.submittedAt | date: 'on %d/%m at %H:%M' }}
                  </span>
                  {% endif %}
                </div>
              </div>
            </div>
          {% endfor %}
        </div>
      </div>
    </div>
  {% endif %}
</div>
<div class="title_bar">
  <i class="ti ti-brand-github"></i>
  <span class="title">PR Attention &middot; {{ length }}</span>
</div>
