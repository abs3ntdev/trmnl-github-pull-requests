<div class="layout layout--col ">
  <div class="label">
        <i class="ti ti-brand-github">&nbsp;</i>Open Pull Requests
  </div>
  {% if length == 0 %}
    <div class="layout layout--col">
      <i class="ti ti-check"></i>
      <span>No pull requests open</span>
    </div>
  {% else %}
    <div class="columns">
      <div class="grid grid--cols-1" data-list-limit="true">
        <div class="list" data-overflow="true" data-overflow-counter="true">
          {% for pr in data.search.nodes %}
            {% assign latest_review = pr.reviews.nodes
              | reject: 'author.login', username
              | sort: 'submittedAt'
              | last
            %}
            {% assign review_status = pr.reviewDecision | default: latest_review.state %}
            <div class="item {% if review_status == "REVIEW_REQUIRED" or review_status == "CHANGES_REQUESTED" %} item--emphasis-3 {% elsif review_status == "COMMENTED" %} item--emphasis-2 {% endif %} ">
              <div class="meta w--5">
                <span class="index ml--0.5" data-pixel-perfect="true">
                  {% case review_status %}
                    {% when 'APPROVED' %}
                      <div class="approved-icon svg-icon-small"></div>
                    {% when 'CHANGES_REQUESTED' %}
                      <div class="changes-requested-icon svg-icon-small"></div>
                    {% when 'COMMENTED' %}
                      <div class="commented-icon svg-icon-small"></div>
                    {% when 'PENDING' %}
                      <div class="pending-icon svg-icon-small"></div>
                    {% when 'REVIEW_REQUIRED' %}
                      <div class="review-required-icon svg-icon-small"></div>
                    {% else %}
                      <div class="need-attention-icon svg-icon-small"></div>
                  {% endcase %}
                </span>
              </div>
              <div class="content">
                <span class="title title--small">
                  {% if pr.isDraft %}
                    <i class="ti ti-git-pull-request-draft"></i>
                  {% else %}
                    <i class="ti ti-git-pull-request"></i>
                  {% endif %}
                  {{ pr.title | truncate: 40 }}
                  <span class="label label--small "> #{{ pr.number }} </span>
                </span>
                <span class="description">
                  <i class="ti ti-world"></i> {{ pr.repository.name }}
                  <span class="label label--small label--underline">
                    <i class="ti ti-message"></i> &nbsp;{{ comments | plus: pr.comments.totalCount }}
                  </span>
                </span>
              </div>
            </div>
          {% endfor %}
        </div>
      </div>
    </div>
  {% endif %}
</div>
<div class="title_bar">
  <i class="ti ti-brand-github"></i>
  <span class="title">Open Pull Requests of {{ username }}</span>
</div>
